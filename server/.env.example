# Copy to .env and fill in values
DATABASE_URL="postgresql://momentum:momentum@localhost:5432/momentum?schema=public"
DATABASE_URL_TEST="postgresql://momentum:momentum@localhost:5432/momentum_test?schema=public"
# Locally this matches DATABASE_URL (no pooler). On Neon, DATABASE_URL is the
# pooled (-pooler) connection string and DIRECT_URL is the unpooled one —
# `prisma migrate` needs the direct connection, the app uses the pooled one.
DIRECT_URL="postgresql://momentum:momentum@localhost:5432/momentum?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3000
NODE_ENV=development
